generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model exercises {
  id              Int           @id @default(autoincrement())
  workout_day_id  Int
  muscle_group_id Int
  exercise_name   String        @db.VarChar(200)
  notes           String?
  created_at      DateTime      @default(now()) @db.Timestamp(6)
  updated_at      DateTime      @default(now()) @db.Timestamp(6)
  total_reps      Int           @default(0)
  weight          Decimal       @default(0) @db.Decimal(10, 2)
  total_sets      Int           @default(0)
  muscle_groups   muscle_groups @relation(fields: [muscle_group_id], references: [id], onUpdate: NoAction)
  workout_days    workout_days  @relation(fields: [workout_day_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([muscle_group_id], map: "idx_exercises_muscle_group")
  @@index([workout_day_id], map: "idx_exercises_workout_day")
  @@index([workout_day_id, muscle_group_id], map: "idx_exercises_workout_day_muscle_group")
}

model muscle_groups {
  id                        Int                         @id @default(autoincrement())
  name                      String                      @unique @db.VarChar(100)
  description               String?
  created_at                DateTime?                   @default(now()) @db.Timestamp(6)
  exercises                 exercises[]
  snapshot_exercises        snapshot_exercises[]
  snapshot_workout_day_sets snapshot_workout_day_sets[]
  workout_day_sets          workout_day_sets[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model snapshot_exercises {
  id                      Int                   @id @default(autoincrement())
  snapshot_workout_day_id Int
  original_exercise_id    Int
  exercise_name           String                @db.VarChar(200)
  muscle_group_id         Int
  notes                   String?
  created_at              DateTime              @default(now()) @db.Timestamp(6)
  total_reps              Int                   @default(0)
  weight                  Decimal               @default(0) @db.Decimal(10, 2)
  total_sets              Int                   @default(0)
  muscle_groups           muscle_groups         @relation(fields: [muscle_group_id], references: [id], onUpdate: NoAction)
  snapshot_workout_days   snapshot_workout_days @relation(fields: [snapshot_workout_day_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([muscle_group_id], map: "idx_snapshot_exercises_muscle_group")
  @@index([snapshot_workout_day_id], map: "idx_snapshot_exercises_snapshot_workout_day")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model snapshot_workout_day_sets {
  id                          Int                   @id @default(autoincrement())
  snapshot_workout_day_id     Int
  original_workout_day_set_id Int
  muscle_group_id             Int
  number_of_sets              Int
  notes                       String?
  created_at                  DateTime              @default(now()) @db.Timestamp(6)
  muscle_groups               muscle_groups         @relation(fields: [muscle_group_id], references: [id], onUpdate: NoAction)
  snapshot_workout_days       snapshot_workout_days @relation(fields: [snapshot_workout_day_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([snapshot_workout_day_id, muscle_group_id], map: "unique_muscle_per_snapshot_day")
  @@index([snapshot_workout_day_id], map: "idx_snapshot_workout_day_sets_day")
  @@index([muscle_group_id], map: "idx_snapshot_workout_day_sets_muscle")
}

model snapshot_workout_days {
  id                        Int                         @id @default(autoincrement())
  snapshot_id               Int
  original_workout_day_id   Int
  day_number                Int
  day_name                  String                      @db.VarChar(100)
  notes                     String?
  created_at                DateTime                    @default(now()) @db.Timestamp(6)
  snapshot_exercises        snapshot_exercises[]
  snapshot_workout_day_sets snapshot_workout_day_sets[]
  weekly_snapshots          weekly_snapshots            @relation(fields: [snapshot_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([snapshot_id, day_number], map: "unique_day_per_snapshot")
  @@index([snapshot_id], map: "idx_snapshot_workout_days_snapshot")
}

model weekly_snapshots {
  id                    Int                     @id @default(autoincrement())
  routine_id            Int
  week_start_date       DateTime                @db.Date
  created_at            DateTime                @default(now()) @db.Timestamp(6)
  updated_at            DateTime                @default(now()) @db.Timestamp(6)
  snapshot_workout_days snapshot_workout_days[]
  workout_routines      workout_routines        @relation(fields: [routine_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([routine_id, week_start_date], map: "unique_snapshot_per_week")
  @@index([routine_id], map: "idx_weekly_snapshots_routine")
  @@index([week_start_date], map: "idx_weekly_snapshots_week_start")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model workout_day_sets {
  id              Int           @id @default(autoincrement())
  workout_day_id  Int
  muscle_group_id Int
  number_of_sets  Int
  notes           String?
  created_at      DateTime?     @default(now()) @db.Timestamp(6)
  updated_at      DateTime?     @default(now()) @db.Timestamp(6)
  muscle_groups   muscle_groups @relation(fields: [muscle_group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workout_days    workout_days  @relation(fields: [workout_day_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([workout_day_id, muscle_group_id], map: "unique_muscle_per_day")
  @@index([workout_day_id], map: "idx_workout_day_sets_day")
  @@index([muscle_group_id], map: "idx_workout_day_sets_muscle")
}

model workout_days {
  id               Int                @id @default(autoincrement())
  routine_id       Int
  day_number       Int
  day_name         String             @db.VarChar(100)
  notes            String?
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  updated_at       DateTime?          @default(now()) @db.Timestamp(6)
  exercises        exercises[]
  workout_day_sets workout_day_sets[]
  workout_routines workout_routines   @relation(fields: [routine_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([routine_id, day_number], map: "unique_day_per_routine")
  @@index([routine_id], map: "idx_workout_days_routine")
}

model workout_routines {
  id               Int                @id @default(autoincrement())
  name             String             @db.VarChar(200)
  description      String?
  is_active        Boolean?           @default(true)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  updated_at       DateTime?          @default(now()) @db.Timestamp(6)
  weekly_snapshots weekly_snapshots[]
  workout_days     workout_days[]

  @@index([is_active], map: "idx_routines_active")
}
